{
  "$schema": "node_modules/wrangler/config-schema.json",
  // Assets-only Worker: no Worker script ("main") — this is a 100% client-side
  // Vite SPA. Cloudflare serves `./dist` directly as static assets.
  "name": "pamm-kpi",
  "compatibility_date": "2026-07-16",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  }
}
